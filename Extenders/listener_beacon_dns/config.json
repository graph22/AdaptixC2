{
  "extender_type": "listener",
  "extender_file": "listener_beacon_dns.so",

  "listener_name": "BeaconDNS",
  "listener_type": "internal",
  "protocol": "dns",

  "ui": {
    "layout": "glayout",
    "elements": [
      {
        "type": "label",
        "text": "Host & port (Bind):",
        "position": [ 0, 0, 1, 1 ]
      },
      {
        "type": "input",
        "id": "host_bind",
        "editable": "false",
        "position": [ 0, 1, 1, 2 ]
      },
      {
        "type": "spinbox",
        "id": "port_bind",
        "editable": "false",
        "min": 1,
        "max": 65535,
        "value": 53,
        "position": [0, 3, 1, 1]
      },
      {
        "type": "label",
        "text": "Domain:",
        "position": [1, 0, 1, 1]
      },
      {
        "type": "input",
        "id": "domain",
        "editable": "false",
        "position": [1, 1, 1, 3]
      }
    ]
  }
}
